{
    "name": "uneca/dashboard-starter-kit",
    "description": "Dashboard starter kit",
    "keywords": [
        "uneca",
        "census",
        "dashboard-starter-kit"
    ],
    "homepage": "https://github.com/tech-acs/chimera-starter-kit",
    "license": "MIT",
    "authors": [
        {
            "name": "UNECA",
            "email": "tamerat@un.org",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-intl": "*",
        "ext-redis": "*",
        "ext-zip": "*",
        "laravel/jetstream": "^5.0",
        "laravel/mcp": "^0.7.0",
        "livewire/livewire": "^3.4",
        "opcodesio/log-viewer": "^3.10",
        "spatie/laravel-package-tools": "^1.16",
        "spatie/laravel-translatable": "^6.2"
    },
    "require-dev": {
        "laravel/boost": "^2.0",
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^11.1",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Uneca\\Chimera\\": "src"
        },
        "files": [
            "src/Services/Helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Actions\\Maker\\": "deploy/actions/Maker",
            "Uneca\\Chimera\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest --no-coverage",
        "test-coverage": "vendor/bin/pest coverage",
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ],
        "lint": [
            "@php vendor/bin/pint --ansi"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": false,
            "phpstan/extension-installer": false
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Uneca\\Chimera\\ChimeraServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
