{
    "name": "uneca/dashboard-starter-kit",
    "description": "Dashboard starter kit",
    "keywords": [
        "uneca",
        "census",
        "dashboard-starter-kit"
    ],
    "homepage": "https://github.com/tech-acs/chimera-starter-kit",
    "license": "MIT",
    "authors": [
        {
            "name": "UNECA",
            "email": "tamerat@un.org",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-intl": "*",
        "ext-zip": "*",
        "ext-redis": "*",
        "spatie/laravel-package-tools": "^1.16",
        "laravel/jetstream": "^5.0",
        "livewire/livewire": "^3.4",
        "spatie/laravel-translatable": "^6.2",
        "opcodesio/log-viewer": "^3.10",
        "laravel/mcp": "v0.7.0"
    },
    "require-dev": {
        "laravel/boost": "^2.0",
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Uneca\\Chimera\\": "src"
        },
        "files": [
            "src/Services/Helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Uneca\\Chimera\\Tests\\": "tests"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest coverage"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": false,
            "phpstan/extension-installer": false
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Uneca\\Chimera\\ChimeraServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
